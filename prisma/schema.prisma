generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Court {
  id          String     @id @default(uuid())
  name        String
  type        String     // "hard", "clay", "padel"
  description String?
  isActive    Boolean    @default(true)
  isFull      Boolean    @default(false)
  basePrice   Float      @default(50)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  timeSlots   TimeSlot[]
  bookings    Booking[]
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  phone         String?
  ageConfirmed  Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model TimeSlot {
  id          String    @id @default(uuid())
  courtId     String
  date        String    // Format: "YYYY-MM-DD"
  startTime   String    // Format: "HH:mm"
  endTime     String    // Format: "HH:mm"
  isBlocked   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  court       Court     @relation(fields: [courtId], references: [id])
  bookings    Booking[]

  @@unique([courtId, date, startTime])
}

model Booking {
  id              String   @id @default(uuid())
  userId          String
  slotId          String
  courtId         String
  roomNumber             String?
  equipmentRental        Boolean  @default(false)
  professionalEquipment  Boolean  @default(false)
  ballsOnly              Boolean  @default(false)
  coaching               Boolean  @default(false)
  professionalCoaching   Boolean  @default(false)
  status          String   @default("pending") // pending, confirmed, cancelled, completed
  totalPrice      Float
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  timeSlot        TimeSlot @relation(fields: [slotId], references: [id])
  court           Court    @relation(fields: [courtId], references: [id])
  payment         Payment?
}

model Setting {
  key   String @id
  value String
}

model Payment {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  stripeId    String?
  amount      Float
  status      String   @default("pending") // pending, succeeded, failed

  booking     Booking  @relation(fields: [bookingId], references: [id])
}
